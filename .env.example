VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cadena de conexion Postgres para backups/restore (db:backup / db:restore).
# Usa el "Session pooler" (puerto 5432): Dashboard -> Connect -> Session pooler.
# El usuario es postgres.<project-ref> y el host es el del pooler de tu region.
SUPABASE_DB_URL=postgresql://postgres.your-project:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
